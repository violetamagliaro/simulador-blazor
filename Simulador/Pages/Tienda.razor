@page "/tienda"
@using TarjetaSube.Models.Tienda


<h2 class="sr-only">Tienda con estantes de madera, productos y carrito</h2>



<div class="tienda-wrap">
    @if (mostrarTicket)
    {
        <div class="overlay" @onclick="CerrarTicket">
            <div class="ticket" @onclick:stopPropagation="true">
                <div class="ticket-header">
                    <i class="ti ti-receipt" aria-hidden="true"></i> Ticket de compra
                </div>
                <div class="ticket-fecha">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
                <div class="ticket-divider"></div>
                @foreach (var item in itemsTicket)
                {
                    <div class="ticket-row">
                        <span>@ObtenerEmoji(item.Producto.Nombre) @item.Producto.Nombre x@item.Cantidad</span>
                        <span>$@((item.Producto.PrecioVenta * item.Cantidad).ToString("N0"))</span>
                    </div>
                }
                <div class="ticket-divider"></div>
                <div class="ticket-total">
                    <span>Total</span>
                    <span>$@totalTicket.ToString("N0")</span>
                </div>
                <div class="ticket-gracias">¡Gracias por su compra!</div>
                <button class="ticket-cerrar" @onclick="CerrarTicket">Cerrar</button>
            </div>
        </div>
    }

    <div class="@(mostrarTicket ? "borroso" : "")">

        <div class="top-bar">
            <div class="top-title">
                <i class="ti ti-building-store" aria-hidden="true"></i> MiniMarket
            </div>
            <div class="top-caja">
                <i class="ti ti-cash" aria-hidden="true"></i> Caja: $@tienda.DineroEnCaja.ToString("N0")
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="toast">@mensaje</div>
        }

        <div class="sala">
            <div class="estantes">
                @for (int e = 0; e < 3; e++)
                {
                    var productosEstante = tienda.Productos.Skip(e * 4).Take(4).ToList();
                    <div class="estante">
                        <div class="estante-fondo">
                            <div class="estante-productos">
                                @foreach (var producto in productosEstante)
                                {
                                    <div class="producto @(producto.Stock == 0 ? "sin-stock" : "")"
                                         @onclick="() => { if (producto.Stock > 0) Agregar(producto); }">
                                        <div class="producto-emoji">@ObtenerEmoji(producto.Nombre)</div>
                                        <div class="producto-nombre">@producto.Nombre</div>
                                        <div class="producto-precio">$@producto.PrecioVenta.ToString("N0")</div>
                                        <div class="producto-stock">Stock: @producto.Stock</div>
                                        @if (producto.Stock == 0)
                                        {
                                            <div class="agotado-badge">Agotado</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="estante-borde-superior"></div>
                        <div class="estante-tabla"></div>
                        <div class="estante-sombra"></div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="bottom-bar">
        <div class="carrito-icono">
            🛒
            <i class="ti ti-shopping-cart" aria-hidden="true"></i>
            @if (carrito.CantidadProductos > 0)
            {
                <span class="carrito-badge">@carrito.CantidadProductos</span>
            }
        </div>
        <div class="carrito-items">
            @if (carrito.Items.Count == 0)
            {
                <span class="carrito-vacio">Carrito vacío</span>
            }
            else
            {
                @foreach (var item in carrito.Items)
                {
                    <span class="carrito-chip">@(ObtenerEmoji(item.Producto.Nombre)) x@(item.Cantidad)</span>
                }
            }
        </div>
        <div class="carrito-derecha">
            <div class="carrito-total">$@carrito.Total.ToString("N0")</div>
            <button class="btn-vaciar" @onclick="Vaciar" disabled="@(carrito.Items.Count == 0)">
                <i class="ti ti-trash" aria-hidden="true"></i> Vaciar
            </button>
            <button class="btn-cobrar" @onclick="Cobrar" disabled="@(carrito.Items.Count == 0)">
                <i class="ti ti-check" aria-hidden="true"></i> Cobrar
            </button>
        </div>
    </div>

</div>

@code {
    private TarjetaSube.Models.Tienda.Tienda tienda = new();
    private TarjetaSube.Models.Tienda.Carrito carrito = new();
    private string mensaje = "";
    private bool mostrarTicket = false;
    private List<ItemCarrito> itemsTicket = new();
    private decimal totalTicket = 0;

    private void Agregar(Producto producto)
    {
        carrito.AgregarProducto(producto);
        mensaje = $"{ObtenerEmoji(producto.Nombre)} {producto.Nombre} agregado al carrito";
    }

    private void Vaciar()
    {
        foreach (var item in carrito.Items)
            item.Producto.Stock += item.Cantidad;
        carrito.Vaciar();
        mensaje = "Carrito vaciado";
    }

    private void Cobrar()
    {
        if (carrito.Total <= 0) return;
        itemsTicket = carrito.Items.ToList();
        totalTicket = carrito.Total;
        tienda.AgregarDinero(carrito.Total);
        carrito.Vaciar();
        mostrarTicket = true;
        mensaje = "";
    }

    private void CerrarTicket() => mostrarTicket = false;

    private string ObtenerEmoji(string nombre) => nombre.ToLower() switch
    {
        "chocolate" => "🍫",
        "café" => "☕",
        "galletitas" => "🍪",
        "gaseosa" => "🥤",
        "pizza" => "🍕",
        "manzana" => "🍎",
        "arroz" => "🍚",
        "leche" => "🥛",
        "yogur" => "🍶",
        "fideos" => "🍝",
        "manteca" => "🧈",
        "jugo" => "🧃",
        _ => "📦"
    };
}

<style>
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        border: 0;
    }

    .tienda-wrap {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: #2C1A0E;
        font-family: system-ui, sans-serif;
        overflow: hidden;
        transition: filter 0.2s;
        position: relative;
    }

    .borroso {
        filter: blur(4px);
        pointer-events: none;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 24px;
        background: #1A0F07;
        color: #F5E6D0;
        flex-shrink: 0;
        margin: 0;
    }

    .top-title {
        font-size: 17px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .top-caja {
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255,255,255,0.08);
        padding: 4px 14px;
        border-radius: 20px;
    }

    .toast {
        background: #E1F5EE;
        color: #085041;
        font-size: 12px;
        padding: 5px 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .sala {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 16px 0;
        background: #2C1A0E;
    }

    .estantes {
        width: 80%;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .estante {
        position: relative;
    }

    .estante-fondo {
        background: repeating-linear-gradient( 90deg, rgba(0,0,0,0.06) 0px, rgba(0,0,0,0.06) 1px, transparent 1px, transparent 38px ), repeating-linear-gradient( 180deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 12px ), #C68642;
        border-radius: 4px 4px 0 0;
        padding: 10px 20px 8px;
        border-left: 10px solid #8B5E3C;
        border-right: 10px solid #8B5E3C;
        border-top: 3px solid #D4A060;
    }

    .estante-productos {
        display: flex;
        gap: 6px;
        justify-content: space-around;
    }

    .estante-tabla {
        height: 18px;
        background: linear-gradient(180deg, #8B5020 0%, #6B3A14 50%, #5A3010 100%);
        border-left: 10px solid #3D1F08;
        border-right: 10px solid #3D1F08;
        position: relative;
    }

    .estante-tabla::before {
        content: '';
        position: absolute;
        top: 4px;
        left: 14px;
        right: 14px;
        height: 2px;
        background: rgba(255,255,255,0.1);
        border-radius: 1px;
    }

    .estante-sombra {
        height: 7px;
        background: rgba(0,0,0,0.4);
        border-radius: 0 0 6px 6px;
        margin: 0 6px;
        filter: blur(3px);
    }

    .producto {
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        padding: 6px 8px;
        border-radius: 6px;
        border: 1.5px solid transparent;
        transition: background 0.15s, transform 0.1s;
        flex: 1;
        position: relative;
        min-width: 0;
    }

    .producto:hover {
        background: rgba(255,255,255,0.18);
        border-color: rgba(255,220,150,0.5);
        transform: translateY(-4px);
    }

    .producto.sin-stock {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .producto.sin-stock:hover {
        transform: none;
        background: transparent;
    }

    .producto-emoji {
        font-size: 30px;
        line-height: 1;
    }

    .producto-nombre {
        font-size: 12px;
        font-weight: 500;
        color: #FFF8EE;
        margin-top: 4px;
        text-align: center;
        text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    }

    .producto-precio {
        font-size: 12px;
        font-weight: 500;
        color: #A8FFDB;
        text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    }

    .producto-stock {
        font-size: 11px;
        color: #FFF0CC;
        text-shadow: 0 1px 2px rgba(0,0,0,0.7);
    }

    .agotado-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        background: #FCEBEB;
        color: #A32D2D;
        font-size: 9px;
        font-weight: 600;
        padding: 1px 5px;
        border-radius: 8px;
    }

    .bottom-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 24px;
        background: #1A0F07;
        border-top: 2px solid #5C3010;
        flex-shrink: 0;
        min-height: 80px;
    }

    .carrito-icono {
        position: relative;
        flex-shrink: 0;
        line-height: 1;
        font-size: 48px;
    }

    .carrito-badge {
        position: absolute;
        top: -5px;
        right: -8px;
        background: #1D9E75;
        color: white;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        font-size: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    .carrito-items {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        flex: 1;
        align-items: center;
    }

    .carrito-vacio {
        font-size: 13px;
        color: #6B5040;
    }

    .carrito-chip {
        background: rgba(255,255,255,0.08);
        color: #F5E6D0;
        font-size: 12px;
        padding: 3px 10px;
        border-radius: 12px;
        border: 0.5px solid rgba(255,255,255,0.1);
    }

    .carrito-derecha {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .carrito-total {
        font-size: 22px;
        font-weight: 500;
        color: #F5E6D0;
        min-width: 80px;
        text-align: right;
    }

    .btn-vaciar, .btn-cobrar {
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: opacity 0.15s;
    }

        .btn-vaciar:disabled, .btn-cobrar:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

    .btn-vaciar {
        background: #7a2e2e;
        color: #FCEBEB;
    }

    .btn-cobrar {
        background: #1D9E75;
        color: white;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .ticket {
        background: white;
        border-radius: 12px;
        padding: 28px 32px;
        width: 340px;
        font-family: 'Courier New', monospace;
    }

    .ticket-header {
        font-size: 17px;
        font-weight: 600;
        color: #111;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
    }

    .ticket-fecha {
        font-size: 12px;
        color: #888;
        margin-bottom: 10px;
    }

    .ticket-divider {
        border-top: 1px dashed #ccc;
        margin: 8px 0;
    }

    .ticket-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: #333;
        padding: 3px 0;
    }

    .ticket-total {
        display: flex;
        justify-content: space-between;
        font-size: 17px;
        font-weight: 700;
        color: #111;
        padding: 4px 0;
    }

    .ticket-gracias {
        text-align: center;
        font-size: 12px;
        color: #888;
        margin-top: 10px;
    }

    .ticket-cerrar {
        display: block;
        width: 100%;
        margin-top: 14px;
        padding: 10px;
        background: #1D9E75;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    .borroso {
        filter: blur(4px);
        pointer-events: none;
        height: 100%;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    @@media (max-width: 768px) {

        html, body {
            overflow-y: auto;
        }

        .tienda-wrap {
            height: auto;
            min-height: 100vh;
            overflow-y: auto;
        }

        .sala {
            overflow-y: visible;
            padding-bottom: 20px;
        }

        .bottom-bar {
            position: static;
        }

        .estantes {
            width: 95%;
        }

        .estante-productos {
            flex-wrap: wrap;
            gap: 10px;
        }

        .producto {
            flex: 0 0 calc(50% - 10px);
            min-width: 100px;
        }
    }

</style>